{
  "version": 2,
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "../src/static/dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/main.py" },
    { "src": "/static/dist/(.*)", "dest": "src/static/dist/$1" },
    { "src": "/(.*)", "dest": "src/static/dist/index.html" }
  ]
}